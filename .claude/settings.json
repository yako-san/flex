{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(pnpm install)",
      "Bash(pnpm install --frozen-lockfile)",
      "Bash(pnpm dev)",
      "Bash(pnpm test)",
      "Bash(pnpm test:watch)",
      "Bash(pnpm typecheck)",
      "Bash(pnpm lint)",
      "Bash(pnpm build)",
      "Bash(pnpm db:format)",
      "Bash(pnpm db:validate)",
      "Bash(pnpm db:generate)",
      "Bash(pnpm prisma:*)",
      "Bash(pnpm exec:*)",
      "Bash(git status)",
      "Bash(git status -s)",
      "Bash(git diff)",
      "Bash(git diff --staged)",
      "Bash(git diff --cached)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(git stash list)",
      "Bash(git fetch:*)",
      "Bash(git remote:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(rg:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(node --version)",
      "Bash(pnpm --version)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "f=$(jq -r '.tool_input.file_path // empty'); case \"$f\" in *.ts|*.tsx) pnpm exec eslint --fix \"$f\" 2>/dev/null || true ;; esac"
          }
        ]
      }
    ]
  }
}
