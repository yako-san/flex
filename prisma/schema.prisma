// =============================================================================
// Flex v2 — schéma Prisma
// IDs : préfixe + ULID (ex `velo_01HXR...`). Generation côté app (lib/ids.ts).
// Soft delete : deletedAt nullable + index partiel sur les entités métier.
// Audit : createdAt/updatedAt/createdById/updatedById + table audit_log.
// Multi-tenant : toute donnée business porte un workshopId (sauf User).
// =============================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  // Vercel Marketplace (Neon) injecte DATABASE_URL (pooled, pgbouncer) et
  // DATABASE_URL_UNPOOLED (direct, requis pour migrations/introspection).
  // On aligne directUrl sur ce que Vercel fournit nativement.
  directUrl  = env("DATABASE_URL_UNPOOLED")
  extensions = [pg_trgm, citext]
}

// =============================================================================
// TENANT & AUTH
// =============================================================================

model Workshop {
  id            String @id
  slug          String @unique
  name          String
  country       String @db.VarChar(2) // ISO 3166-1 alpha-2 (CA, US, MX...)
  currency      String @db.VarChar(3) // ISO 4217 (CAD, USD, MXN...)
  timezone      String // IANA (ex America/Montreal)
  defaultLocale String @map("default_locale") @db.VarChar(10) // BCP 47 (fr-CA)
  activeLocales Json   @map("active_locales") // ex ["fr-CA","en-CA","es-MX"]

  fiscalEntity Json? @map("fiscal_entity") // raison sociale, NEQ, TPS#, TVQ#, adresse...

  // Logo en base64 (PNG). Utilisé pour PDFs + favicon dynamique. Max ~500KB.
  logoBase64 String? @map("logo_base64")

  // Multi-tenant : chaque Workshop est lié à une Clerk Organization.
  // Null tant que pas linké (workshop seed pré-Clerk Orgs).
  clerkOrgId String? @unique @map("clerk_org_id")

  // Données v1 importées sans mappage relationnel (factures journal, etc.)
  // Stocké brut pour traçabilité ; le mappage détaillé peut se faire plus tard.
  legacyV1Extras Json? @map("legacy_v1_extras")

  stripeCustomerId     String? @unique @map("stripe_customer_id")
  stripeSubscriptionId String? @unique @map("stripe_subscription_id")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  members        WorkshopMember[]
  clients        Client[]
  velos          Velo[]
  bdcs           Bdc[]
  services       Service[]
  pieces         Piece[]
  forfaits       Forfait[]
  marques        Marque[]
  factures       FactureLog[]
  ventes         VenteDirecte[]
  pos            Po[]
  equipeMembers  EquipeMember[]
  counters       Counter[]
  translations   Translation[]
  stockMovements StockMovement[]
  auditLogs      AuditLog[]
  legacyMappings LegacyIdMapping[]

  @@index([deletedAt])
  @@map("workshop")
}

model User {
  id            String  @id // user_<ulid>
  clerkUserId   String  @unique @map("clerk_user_id")
  email         String  @unique @db.Citext
  fullName      String? @map("full_name")
  defaultLocale String  @default("fr-CA") @map("default_locale") @db.VarChar(10)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  memberships WorkshopMember[]

  @@map("user")
}

enum WorkshopRole {
  OWNER
  ADMIN
  MECANO

  @@map("workshop_role")
}

model WorkshopMember {
  id         String       @id // member_<ulid>
  workshopId String       @map("workshop_id")
  userId     String       @map("user_id")
  role       WorkshopRole

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  workshop Workshop @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workshopId, userId])
  @@index([userId])
  @@map("workshop_member")
}

// =============================================================================
// I18N — table de traduction normalisée (catalogue user-generated)
// Pour les UI strings : voir messages/{locale}.json côté next-intl.
// =============================================================================

enum TranslationEntityType {
  SERVICE
  PIECE
  FORFAIT
  MARQUE

  @@map("translation_entity_type")
}

enum TranslationSource {
  USER // saisi ou édité manuellement par un membre du workshop
  DEEPL // généré par DeepL
  LLM // généré par Claude / GPT (fallback locales DeepL non couvertes)

  @@map("translation_source")
}

model Translation {
  id         String                @id // tr_<ulid>
  workshopId String                @map("workshop_id")
  entityType TranslationEntityType @map("entity_type")
  entityId   String                @map("entity_id")
  field      String // 'label' | 'description' | 'category'...
  locale     String                @db.VarChar(10) // BCP 47 (fr-CA, es-MX...)
  value      String

  source       TranslationSource
  reviewedAt   DateTime?         @map("reviewed_at")
  reviewedById String?           @map("reviewed_by_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  workshop Workshop @relation(fields: [workshopId], references: [id], onDelete: Cascade)

  @@unique([workshopId, entityType, entityId, field, locale])
  @@index([workshopId, entityType, entityId])
  @@index([reviewedAt]) // pour lister les traductions à réviser
  @@map("translation")
}

// =============================================================================
// CATALOGUE
// =============================================================================

model Marque {
  id         String @id // marque_<ulid>
  workshopId String @map("workshop_id")
  // Le `nom` ici est le slug canonique (case-insensitive). Affichage via Translation.
  nom        String @db.Citext

  legacyRawV1 Json? @map("legacy_raw_v1")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  workshop Workshop @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  velos    Velo[]

  @@unique([workshopId, nom])
  @@index([deletedAt])
  @@map("marque")
}

model Service {
  id         String  @id // service_<ulid>
  workshopId String  @map("workshop_id")
  legacyCode String? @map("legacy_code") // ex S00001 (référence v1)

  // Slug canonique. Affichage via Translation.value.
  labelCanonical String  @map("label_canonical")
  categorie      String?
  // Chemin hiérarchique de catégorie v1 (ex "2. Transmission, Cartouches BB")
  // sert à matcher les services aux pièces dans les BDT.
  categoriePrio  String? @map("categorie_prio")

  dureeMinutes Int?    @map("duree_minutes")
  prix         Decimal @db.Decimal(12, 2)
  taxable      Boolean @default(true)

  legacyRawV1 Json? @map("legacy_raw_v1")

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  createdById String?   @map("created_by_id")
  updatedById String?   @map("updated_by_id")

  workshop Workshop  @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  bdcItems BdcItem[]

  @@unique([workshopId, legacyCode])
  @@index([workshopId, deletedAt])
  @@map("service")
}

model Piece {
  id         String  @id // piece_<ulid>
  workshopId String  @map("workshop_id")
  legacyCode String? @map("legacy_code") // ex P00001

  // Slug canonique. Affichage via Translation.value.
  nomCanonical String  @map("nom_canonical")
  // Optionnel : v1 a des entrées sans sku réel ("page Babac", "lien", vide).
  // L'@@unique([workshopId, sku]) reste effectif : Postgres considère chaque
  // NULL comme distinct, donc plusieurs pièces sans sku peuvent coexister.
  sku          String?
  codeBarre    String? @map("code_barre")
  categorie    String?
  fournisseur  String?

  prixAchat Decimal? @map("prix_achat") @db.Decimal(12, 2)
  prixBase  Decimal? @map("prix_base") @db.Decimal(12, 2)
  prixVente Decimal  @map("prix_vente") @db.Decimal(12, 2)
  prixCost  Decimal? @map("prix_cost") @db.Decimal(12, 2)
  prixBdc   Decimal? @map("prix_bdc") @db.Decimal(12, 2)
  taxable   Boolean  @default(true)

  // Stock cached. Source de vérité = StockMovement (recalcul par job).
  // AB physique = SUM(StockMovement.delta) de type entrée/sortie.
  // AC réservé  = pièces engagées dans BDC en statut ENGAGED.
  stockPhysique Int @default(0) @map("stock_physique")
  stockReserve  Int @default(0) @map("stock_reserve")

  legacyRawV1 Json? @map("legacy_raw_v1")

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  createdById String?   @map("created_by_id")
  updatedById String?   @map("updated_by_id")

  workshop       Workshop           @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  bdcItems       BdcItem[]
  venteItems     VenteDirecteItem[]
  poItems        PoItem[]
  stockMovements StockMovement[]

  @@index([workshopId, deletedAt])
  @@index([workshopId, codeBarre])
  @@index([workshopId, legacyCode])
  @@index([workshopId, sku])
  @@map("piece")
}

model Forfait {
  id             String  @id // forfait_<ulid>
  workshopId     String  @map("workshop_id")
  legacyCode     String? @map("legacy_code")
  labelCanonical String  @map("label_canonical")

  prix         Decimal @db.Decimal(12, 2)
  dureeMinutes Int?    @map("duree_minutes")
  taxable      Boolean @default(true)

  legacyRawV1 Json? @map("legacy_raw_v1")

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  createdById String?   @map("created_by_id")
  updatedById String?   @map("updated_by_id")

  workshop      Workshop              @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  taskTemplates ForfaitTaskTemplate[]
  bdcItems      BdcItem[]

  @@unique([workshopId, legacyCode])
  @@index([workshopId, deletedAt])
  @@map("forfait")
}

// Template de sous-tâche d'un forfait (workflow mecano).
// Au moment d'ajouter un Forfait à un BDT, les templates sont copiés en
// BdcItemTask avec labelSnapshot. Permet de cocher la progression sans casser
// l'unité facturable du forfait (1 ligne sur la facture, N tâches workflow).
//
// Ces tâches NE SONT PAS des Services facturables individuellement — elles
// vivent dans une table dédiée pour préserver la sémantique.
model ForfaitTaskTemplate {
  id             String @id // ftt_<ulid>
  forfaitId      String @map("forfait_id")
  labelCanonical String @map("label_canonical")
  position       Int

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  forfait Forfait @relation(fields: [forfaitId], references: [id], onDelete: Cascade)

  @@unique([forfaitId, position])
  @@map("forfait_task_template")
}

// =============================================================================
// CLIENTS & VÉLOS
// =============================================================================

enum CommPref {
  EMAIL
  SMS
  TELEPHONE
  AUCUN

  @@map("comm_pref")
}

model Client {
  id         String @id // client_<ulid>
  workshopId String @map("workshop_id")

  prenom        String
  nom           String
  telephone     String? // E.164 normalisé
  indicatif     String?  @db.VarChar(5) // ex +1, +52
  courriel      String?  @db.Citext
  commPref      CommPref @default(EMAIL) @map("comm_pref")
  lang          String   @db.VarChar(10) // BCP 47
  lead          String? // source d'acquisition (referral, web, etc)
  remiseDefault Decimal? @map("remise_default") @db.Decimal(5, 2) // pourcentage, ex 10.00 = 10%

  adressePostale Json?   @map("adresse_postale")
  notes          String?

  // Snapshot brut de la ligne v1 source pour traçabilité totale (champs
  // v1 non mappés en colonnes propres : googleResourceName, dateIn, dateOut...)
  legacyRawV1 Json? @map("legacy_raw_v1")

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  createdById String?   @map("created_by_id")
  updatedById String?   @map("updated_by_id")

  workshop Workshop       @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  velos    Velo[]
  factures FactureLog[]
  ventes   VenteDirecte[]

  @@index([workshopId, deletedAt])
  @@index([workshopId, courriel])
  @@index([workshopId, telephone])
  @@map("client")
}

enum VeloStatus {
  RV // rendez-vous fixé
  RECU // vélo reçu à l'atelier
  EN_ATTENTE // en attente d'action (équivalent v1 "EN ATTENTE")
  EVAL // en évaluation
  APPROUVE // évaluation approuvée par le client
  ON_BENCH // sur le banc, en cours de réparation
  CTRL_QLTE // contrôle qualité
  FINI // travaux terminés
  LIVRE // livré au client
  FACTURER // à facturer
  FACTURE // facturé

  @@map("velo_status")
}

model Velo {
  id         String  @id // velo_<ulid>
  workshopId String  @map("workshop_id")
  clientId   String  @map("client_id")
  marqueId   String? @map("marque_id")

  // Numéro séquentiel atelier-scope (ex 001, 002... — voir Counter)
  veloNumero Int @map("velo_numero")

  status VeloStatus @default(RV)

  date1 DateTime?
  date2 DateTime?
  date3 DateTime?

  modele      String?
  couleur     String?
  taille      String?
  numeroSerie String? @map("numero_serie")

  evalMecanoId String? @map("eval_mecano_id")
  mecaMecanoId String? @map("meca_mecano_id")
  ctrlMecanoId String? @map("ctrl_mecano_id")

  noteVelo          String? @map("note_velo") // interne
  noteClientEval    String? @map("note_client_eval") // affiché PDF éval
  noteClientFacture String? @map("note_client_facture") // affiché PDF facture
  notes             String? // libre interne

  // Snapshot brut de la ligne v1 source (services/pieces concaténés, dates v1, etc.)
  legacyRawV1 Json? @map("legacy_raw_v1")

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  createdById String?   @map("created_by_id")
  updatedById String?   @map("updated_by_id")

  workshop   Workshop      @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  client     Client        @relation(fields: [clientId], references: [id], onDelete: Restrict)
  marque     Marque?       @relation(fields: [marqueId], references: [id], onDelete: SetNull)
  evalMecano EquipeMember? @relation("VeloEvalMecano", fields: [evalMecanoId], references: [id], onDelete: SetNull)
  mecaMecano EquipeMember? @relation("VeloMecaMecano", fields: [mecaMecanoId], references: [id], onDelete: SetNull)
  ctrlMecano EquipeMember? @relation("VeloCtrlMecano", fields: [ctrlMecanoId], references: [id], onDelete: SetNull)
  // Plusieurs BDC dans l'historique d'un même vélo (cycles de visites).
  // En v1 export, un BDC actif peut coexister avec ses archives.
  bdcs       Bdc[]

  @@unique([workshopId, veloNumero])
  @@index([workshopId, status])
  @@index([clientId])
  @@index([workshopId, deletedAt])
  @@map("velo")
}

// =============================================================================
// BON DE COMMANDE / TRAVAIL (BDC = BDT)
// =============================================================================

enum BdcEvalStatus {
  EN_ATTENTE
  APPROUVE
  REDUX // approuvé en réduit (partiel)
  REFUSE

  @@map("bdc_eval_status")
}

enum BdcArchiveStatus {
  ACTIF // en cours, pas encore archivé
  ARCHIVE_FACTURE // facturé, archivé (v1 "FACTURÉ")
  ARCHIVE_A_FACTURER // archivé en attente de facturation (v1 "FACTURER")
  ARCHIVE_REFUSE // client a refusé l'évaluation (v1 "REFUSÉ")
  ARCHIVE_CTRL_QLTE // archivé en contrôle qualité (v1 "CTRL QLTÉ")
  ARCHIVE_EVAL // archivé en évaluation (v1 "ÉVAL.")
  ARCHIVE_LEGACY // archive sans détail (v1 "ARCHIVÉ" générique)

  @@map("bdc_archive_status")
}

enum RemiseType {
  PCT
  FIXED

  @@map("remise_type")
}

model Bdc {
  id         String @id // bdc_<ulid>
  workshopId String @map("workshop_id")
  veloId     String @map("velo_id")

  evalStatus    BdcEvalStatus    @default(EN_ATTENTE) @map("eval_status")
  archiveStatus BdcArchiveStatus @default(ACTIF) @map("archive_status")

  // Workflow v1 : 4 checkboxes + 1 enum eval_status (cascade UI gérée côté app).
  // Mapping v1 → v2 :
  //   v1.checkEval → cbEvalEnvoye  (évaluation envoyée au client)
  //   v1.checkOk   → cbEval        (évaluation faite côté mecano)
  //   v1.checkBds  → cbBonSortie   (bon de sortie imprimé)
  //   v1.checkOut  → cbArchiver    (archivage déclenché)
  cbEvalEnvoye Boolean @default(false) @map("cb_eval_envoye")
  cbEval       Boolean @default(false) @map("cb_eval")
  cbBonSortie  Boolean @default(false) @map("cb_bon_sortie")
  cbArchiver   Boolean @default(false) @map("cb_archiver")

  remiseSvcType  RemiseType? @map("remise_svc_type")
  remiseSvcValue Decimal?    @map("remise_svc_value") @db.Decimal(12, 2)
  remisePceType  RemiseType? @map("remise_pce_type")
  remisePceValue Decimal?    @map("remise_pce_value") @db.Decimal(12, 2)

  // Totaux cachés (recalculés sur write des items). Sources de vérité = items.
  totalServices Decimal @default(0) @map("total_services") @db.Decimal(12, 2)
  totalPieces   Decimal @default(0) @map("total_pieces") @db.Decimal(12, 2)

  notes String?

  // Snapshot brut de la ligne v1 source (note_client/note_facture, items raw, etc.)
  legacyRawV1 Json? @map("legacy_raw_v1")

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  createdById String?   @map("created_by_id")
  updatedById String?   @map("updated_by_id")

  workshop Workshop     @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  velo     Velo         @relation(fields: [veloId], references: [id], onDelete: Cascade)
  items    BdcItem[]
  factures FactureLog[]

  @@index([workshopId, evalStatus])
  @@index([workshopId, archiveStatus])
  @@index([workshopId, deletedAt])
  @@index([veloId])
  @@map("bdc")
}

enum BdcItemKind {
  SERVICE
  PIECE
  FORFAIT

  @@map("bdc_item_kind")
}

model BdcItem {
  id         String      @id // bdci_<ulid>
  workshopId String      @map("workshop_id") // dénormalisé pour query rapide tenant-scope
  bdcId      String      @map("bdc_id")
  kind       BdcItemKind
  position   Int

  // Refs catalogue (une seule remplie selon kind, contrainte CHECK ajoutée par migration SQL)
  serviceId String? @map("service_id")
  pieceId   String? @map("piece_id")
  forfaitId String? @map("forfait_id")

  // Snapshot au moment de l'ajout (résiste aux changements catalogue)
  labelSnapshot     String  @map("label_snapshot")
  unitPriceSnapshot Decimal @map("unit_price_snapshot") @db.Decimal(12, 2)
  taxableSnapshot   Boolean @map("taxable_snapshot")
  qty               Decimal @default(1) @db.Decimal(10, 3)
  total             Decimal @db.Decimal(12, 2) // qty * unitPriceSnapshot après remises de ligne

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  bdc     Bdc           @relation(fields: [bdcId], references: [id], onDelete: Cascade)
  service Service?      @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  piece   Piece?        @relation(fields: [pieceId], references: [id], onDelete: Restrict)
  forfait Forfait?      @relation(fields: [forfaitId], references: [id], onDelete: Restrict)
  tasks   BdcItemTask[]

  @@index([bdcId, position])
  @@index([workshopId, pieceId])
  @@map("bdc_item")
}

enum BdcItemTaskStatus {
  TODO
  DONE
  SKIPPED

  @@map("bdc_item_task_status")
}

// Sous-tâches d'un item kind=FORFAIT (instanciées au moment de l'ajout au BDT
// depuis ForfaitTaskTemplate). Permet au mecano de cocher la progression sans
// casser l'unité facturable du forfait. labelSnapshot fige le texte du template.
model BdcItemTask {
  id            String            @id // task_<ulid>
  bdcItemId     String            @map("bdc_item_id")
  position      Int
  labelSnapshot String            @map("label_snapshot")
  status        BdcItemTaskStatus @default(TODO)
  doneAt        DateTime?         @map("done_at")
  doneById      String?           @map("done_by_id")
  notes         String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  bdcItem BdcItem @relation(fields: [bdcItemId], references: [id], onDelete: Cascade)

  @@index([bdcItemId, position])
  @@map("bdc_item_task")
}

// =============================================================================
// VENTE DIRECTE (au comptoir, sans BDT)
// =============================================================================

enum ModePaiement {
  COMPTANT
  INTERAC
  CARTE
  AUTRE

  @@map("mode_paiement")
}

model VenteDirecte {
  id         String  @id // vente_<ulid>
  workshopId String  @map("workshop_id")
  clientId   String? @map("client_id") // optionnel : vente walk-in

  date          DateTime      @default(now())
  factureNumero String?       @map("facture_numero") // numéro facture émise (si facturée)
  factureDate   DateTime?     @map("facture_date")
  factureUrl    String?       @map("facture_url")
  modePaiement  ModePaiement?

  remiseType  RemiseType? @map("remise_type")
  remiseValue Decimal?    @map("remise_value") @db.Decimal(12, 2)

  totalPieces Decimal @default(0) @map("total_pieces") @db.Decimal(12, 2)
  notes       String?

  legacyRawV1 Json? @map("legacy_raw_v1")

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  createdById String?   @map("created_by_id")
  updatedById String?   @map("updated_by_id")

  workshop Workshop           @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  client   Client?            @relation(fields: [clientId], references: [id], onDelete: SetNull)
  items    VenteDirecteItem[]
  factures FactureLog[]

  @@index([workshopId, deletedAt])
  @@index([workshopId, factureNumero])
  @@map("vente_directe")
}

model VenteDirecteItem {
  id       String  @id // vdi_<ulid>
  venteId  String  @map("vente_id")
  pieceId  String? @map("piece_id") // null si vente libre (pas dans catalogue)
  position Int

  skuSnapshot       String? @map("sku_snapshot")
  nomSnapshot       String  @map("nom_snapshot")
  qty               Decimal @default(1) @db.Decimal(10, 3)
  unitPriceSnapshot Decimal @map("unit_price_snapshot") @db.Decimal(12, 2)
  taxableSnapshot   Boolean @map("taxable_snapshot")
  total             Decimal @db.Decimal(12, 2)

  createdAt DateTime @default(now()) @map("created_at")

  vente VenteDirecte @relation(fields: [venteId], references: [id], onDelete: Cascade)
  piece Piece?       @relation(fields: [pieceId], references: [id], onDelete: SetNull)

  @@index([venteId, position])
  @@map("vente_directe_item")
}

// =============================================================================
// FACTURATION — table unique pour les 3 sources v1 (BDT, ventes, legacy)
// Une facture émise est IMMUTABLE. Annulation = note de crédit (nouvelle ligne).
// =============================================================================

enum FactureType {
  BDC
  VENTE_DIRECTE
  LEGACY
  NOTE_CREDIT

  @@map("facture_type")
}

enum FactureStatut {
  EMIS
  PAYE
  ANNULE

  @@map("facture_statut")
}

model FactureLog {
  id         String @id // facture_<ulid>
  workshopId String @map("workshop_id")

  type          FactureType
  factureNumero String        @map("facture_numero") // ex V0001
  date          DateTime
  modePaiement  ModePaiement?
  statut        FactureStatut @default(EMIS)

  bdcId             String? @map("bdc_id")
  venteId           String? @map("vente_id")
  noteCreditCibleId String? @map("note_credit_cible_id") // FK vers la facture annulée

  clientId String? @map("client_id")

  // Snapshots (immutables après émission)
  taxRatesSnapshot Json  @map("tax_rates_snapshot") // { tps: "0.05", tvq: "0.09975" }
  linesSnapshot    Json  @map("lines_snapshot") // array complète des lignes
  fiscalSnapshot   Json? @map("fiscal_snapshot") // raison sociale, NEQ, TPS#, TVQ# au moment T

  totalServices Decimal @map("total_services") @db.Decimal(12, 2)
  totalPieces   Decimal @map("total_pieces") @db.Decimal(12, 2)
  sousTotal     Decimal @map("sous_total") @db.Decimal(12, 2)
  tps           Decimal @db.Decimal(12, 2)
  tvq           Decimal @db.Decimal(12, 2)
  taxes         Decimal @db.Decimal(12, 2) // tps + tvq, redondant pour ergonomie query
  grandTotal    Decimal @map("grand_total") @db.Decimal(12, 2)

  validation Json? // { validatedBy, validatedAt, signature... }
  notes      String?
  pdfUrl     String? @map("pdf_url")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdById String?  @map("created_by_id")

  workshop        Workshop      @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  bdc             Bdc?          @relation(fields: [bdcId], references: [id], onDelete: SetNull)
  vente           VenteDirecte? @relation(fields: [venteId], references: [id], onDelete: SetNull)
  client          Client?       @relation(fields: [clientId], references: [id], onDelete: SetNull)
  noteCreditCible FactureLog?   @relation("FactureNoteCredit", fields: [noteCreditCibleId], references: [id], onDelete: SetNull)
  notesCredit     FactureLog[]  @relation("FactureNoteCredit")

  @@unique([workshopId, factureNumero])
  @@index([workshopId, date])
  @@index([workshopId, statut])
  @@index([clientId])
  @@map("facture_log")
}

// =============================================================================
// PURCHASE ORDERS (commandes fournisseur)
// =============================================================================

enum PoStatus {
  EN_ATTENTE
  PARTIEL
  RECU
  ANNULE

  @@map("po_status")
}

model Po {
  id            String    @id // po_<ulid>
  workshopId    String    @map("workshop_id")
  poNumero      String    @map("po_numero")
  fournisseur   String
  dateCommande  DateTime  @map("date_commande")
  dateReception DateTime? @map("date_reception")
  status        PoStatus  @default(EN_ATTENTE)
  notes         String?

  legacyRawV1 Json? @map("legacy_raw_v1")

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  createdById String?   @map("created_by_id")
  updatedById String?   @map("updated_by_id")

  workshop Workshop @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  items    PoItem[]

  @@unique([workshopId, poNumero])
  @@index([workshopId, status])
  @@map("po")
}

model PoItem {
  id       String  @id // poi_<ulid>
  poId     String  @map("po_id")
  pieceId  String? @map("piece_id")
  position Int

  skuSnapshot  String? @map("sku_snapshot")
  nomSnapshot  String  @map("nom_snapshot")
  qtyCommandee Decimal @map("qty_commandee") @db.Decimal(10, 3)
  qtyRecue     Decimal @default(0) @map("qty_recue") @db.Decimal(10, 3)
  unitPrice    Decimal @map("unit_price") @db.Decimal(12, 2)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  po    Po     @relation(fields: [poId], references: [id], onDelete: Cascade)
  piece Piece? @relation(fields: [pieceId], references: [id], onDelete: SetNull)

  @@index([poId, position])
  @@map("po_item")
}

// =============================================================================
// STOCK MOVEMENTS — append-only, source de vérité pour reconstituer Piece.stockPhysique
// =============================================================================

enum StockMovementType {
  PO_RECEIVED // entrée stock (réception PO)
  BDC_INVOICED // sortie stock (BDT facturé)
  SALE_INVOICED // sortie stock (vente directe facturée)
  MANUAL_ADJUSTMENT // ajustement manuel (inventaire physique)
  RESERVATION // réservation (delta sur stockReserve, pas stockPhysique)
  RELEASE // libération réservation

  @@map("stock_movement_type")
}

model StockMovement {
  id         String            @id // mov_<ulid>
  workshopId String            @map("workshop_id")
  pieceId    String            @map("piece_id")
  type       StockMovementType
  delta      Decimal           @db.Decimal(10, 3) // signé (+ = entrée, - = sortie)
  reason     String?

  // Lien vers la source du mouvement (pour traçabilité)
  bdcItemId   String? @map("bdc_item_id")
  venteItemId String? @map("vente_item_id")
  poItemId    String? @map("po_item_id")

  createdAt   DateTime @default(now()) @map("created_at")
  createdById String?  @map("created_by_id")

  workshop Workshop @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  piece    Piece    @relation(fields: [pieceId], references: [id], onDelete: Cascade)

  @@index([workshopId, pieceId, createdAt])
  @@index([type])
  @@map("stock_movement")
}

// =============================================================================
// COUNTERS — séquences atelier-scope (factureNumero, veloNumero)
// Update atomique via transaction (SELECT ... FOR UPDATE).
// =============================================================================

enum CounterKind {
  FACTURE_SEQUENCE
  VELO_SEQUENCE
  PO_SEQUENCE

  @@map("counter_kind")
}

model Counter {
  id         String      @id // ctr_<ulid>
  workshopId String      @map("workshop_id")
  kind       CounterKind
  prefix     String? // ex "V" pour FACTURE_SEQUENCE
  current    Int         @default(0)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  workshop Workshop @relation(fields: [workshopId], references: [id], onDelete: Cascade)

  @@unique([workshopId, kind])
  @@map("counter")
}

// =============================================================================
// EQUIPE (mecanos référencés sur les BDT, distincts des WorkshopMember de l'app)
// =============================================================================

model EquipeMember {
  id         String @id // eq_<ulid>
  workshopId String @map("workshop_id")

  prenom    String
  nom       String
  surnom    String // court, ex "yako" — affichage liste BDT
  courriel  String? @db.Citext
  telephone String?
  indicatif String? @db.VarChar(5)
  lang      String  @default("fr-CA") @db.VarChar(10)
  role      String?
  active    Boolean @default(true)
  notes     String?

  legacyRawV1 Json? @map("legacy_raw_v1")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  workshop Workshop @relation(fields: [workshopId], references: [id], onDelete: Cascade)

  evalVelos Velo[] @relation("VeloEvalMecano")
  mecaVelos Velo[] @relation("VeloMecaMecano")
  ctrlVelos Velo[] @relation("VeloCtrlMecano")

  @@unique([workshopId, surnom])
  @@index([workshopId, active])
  @@map("equipe_member")
}

// =============================================================================
// AUDIT LOG — events métier critiques uniquement (pas tous les UPDATE)
// =============================================================================

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  STATUS_CHANGE
  STOCK_MOVEMENT
  INVOICE_EMITTED
  INVOICE_VOIDED
  ROLE_CHANGE
  TRANSLATION_REVIEWED

  @@map("audit_action")
}

model AuditLog {
  id         String      @id // log_<ulid>
  workshopId String      @map("workshop_id")
  actorId    String?     @map("actor_id") // userId ou null si système
  entityType String      @map("entity_type")
  entityId   String      @map("entity_id")
  action     AuditAction
  before     Json?
  after      Json?
  metadata   Json?

  at DateTime @default(now())

  workshop Workshop @relation(fields: [workshopId], references: [id], onDelete: Cascade)

  @@index([workshopId, entityType, entityId])
  @@index([workshopId, at])
  @@index([actorId])
  @@map("audit_log")
}

// =============================================================================
// LEGACY ID MAPPING — traçabilité v1 → v2 (généré par le script d'import)
// =============================================================================

model LegacyIdMapping {
  id         String @id // map_<ulid>
  workshopId String @map("workshop_id")

  entityType String @map("entity_type") // 'piece', 'service', 'velo', 'client', 'facture'...
  legacyId   String @map("legacy_id")
  newId      String @map("new_id")

  // Désambiguïsation : v1 réutilise certains pieceId (P00004 ×3, P00035 ×2,
  // P00040, P00042, P00550 ×2). Le tuple (legacy_id, legacy_sku, legacy_nom)
  // permet de retrouver le bon newId quand un BDT/Vente référence l'ancien ID.
  legacySku String? @map("legacy_sku")
  legacyNom String? @map("legacy_nom")
  notes     String?

  createdAt DateTime @default(now()) @map("created_at")

  workshop Workshop @relation(fields: [workshopId], references: [id], onDelete: Cascade)

  @@index([workshopId, entityType, legacyId])
  @@index([workshopId, entityType, newId])
  @@index([workshopId, entityType, legacyId, legacySku])
  @@map("legacy_id_mapping")
}
